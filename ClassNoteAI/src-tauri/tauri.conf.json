{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClassNoteAI",
  "version": "0.7.0-alpha.1",
  "identifier": "com.classnoteai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClassNote AI",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com https://api.openai.com https://generativelanguage.googleapis.com https://api.groq.com https://api.deepseek.com https://huggingface.co https://*.huggingface.co https://*.instructure.com https://models.github.ai https://auth.openai.com https://chatgpt.com http://localhost:* ipc: http://ipc.localhost; img-src 'self' data: blob: https:; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/videos/*",
            "$APPDATA/videos/**",
            "$APPDATA/audio/*",
            "$APPDATA/audio/**",
            "$HOME/Library/Application Support/com.classnoteai/videos/*",
            "$HOME/Library/Application Support/com.classnoteai/videos/**",
            "$HOME/Library/Application Support/com.classnoteai/audio/*",
            "$HOME/Library/Application Support/com.classnoteai/audio/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/binaries/*": "./binaries/",
      "resources/cuda/*": "./",
      "resources/silero/*": "./resources/silero/",
      "resources/ort/*": "./resources/ort/"
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": null,
      "infoPlist": "Info.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwNzVEQUZFQUIzRTJCMUQKUldRZEt6NnIvdHAxNEY1dVlqN3BobkhoSmpDMHRnK3pMZFhmZmRCRlBWZXdRSkZXL3RyY1pGRHUK",
      "endpoints": [
        "https://github.com/sklonely/ClassNoteAI/releases/latest/download/latest.json"
      ]
    }
  }
}
